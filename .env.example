# ─── Public ───────────────────────────────────────────────────────────────────
# Base URL of the site. In dev this is set in .env.development automatically.
# In production, set this in the Vercel dashboard.
NEXT_PUBLIC_SITE_URL=https://www.rubengonz.com

# ─── Feature flags ────────────────────────────────────────────────────────────
# Set to "true" to show the maintenance page instead of the real site.
# Safe to set in Vercel dashboard per-environment (preview vs production).
MAINTENANCE_MODE=false

# ─── Contact form (Gmail) ─────────────────────────────────────────────────────
# The Gmail address that sends and receives contact form submissions.
# Generate an app password at: myaccount.google.com/apppasswords
# Never commit real values — add these only in Vercel dashboard and .env.local.
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
